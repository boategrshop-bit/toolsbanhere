# ── Server ──────────────────────────────────────────────
PORT=3001
BASE_URL=http://localhost:3001
SESSION_SECRET=เปลี่ยนเป็นสตริงสุ่มอะไรก็ได้

# ── Admin ────────────────────────────────────────────────
# อีเมลที่สมัครด้วยอีเมลนี้จะได้สิทธิ์แอดมินทันที
ADMIN_EMAIL=your-email@gmail.com

# ── Email (Gmail + App Password) ────────────────────────
# วิธีเปิด App Password: myaccount.google.com → Security → 2-Step → App passwords
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# ── Lesson Links ─────────────────────────────────────────
# ลิงก์ที่ส่งให้ผู้เรียนทาง email หลัง approve
# ถ้าไม่มีก็ว่างไว้ได้
LINE_GROUP_LINK=https://line.me/ti/g2/xxxx
